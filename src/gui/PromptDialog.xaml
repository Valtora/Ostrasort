<Window x:Class="Ostrasort.Gui.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ostrasort" SizeToContent="Height" Width="440" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" WindowStyle="ToolWindow">
    <StackPanel Margin="18,14">
        <TextBlock x:Name="TxtPrompt" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <TextBox x:Name="TxtInput" Margin="0,0,0,14" Padding="3,2" FontSize="13"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Padding="16,4" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" Padding="16,4" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
