<Window x:Class="Ostrasort.Gui.InstallConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ostrasort — Install from file" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" WindowStyle="ToolWindow">
    <StackPanel Margin="18,14" MaxWidth="480">
        <TextBlock x:Name="TxtHeader" FontWeight="SemiBold" FontSize="13.5" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <ItemsControl x:Name="ListComponents" Margin="0,0,0,4">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,1,0,1"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl x:Name="ListWarnings" Margin="0,6,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,1,0,1" FontSize="12"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <CheckBox x:Name="ChkOverwrite" Visibility="Collapsed" Margin="0,12,0,0"
                  Content="Overwrite the copy already installed (replaces it)"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnInstall" Content="Install" Padding="14,4" Margin="0,0,8,0" IsDefault="True" Click="Install_Click"/>
            <Button Content="Cancel" Padding="14,4" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
