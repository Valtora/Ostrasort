<Window x:Class="Ostrasort.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gui="clr-namespace:Ostrasort.Gui"
        Title="Ostrasort" Height="760" Width="1120" MinHeight="560" MinWidth="860"
        Icon="/app.ico" WindowStartupLocation="CenterScreen"
        Activated="Window_Activated" Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True" PreviewDragOver="Window_DragOver" PreviewDrop="Window_Drop">
    <Window.Resources>
        <!-- icon + label button for the selected-mod action bar; the MDL2 glyph and
             the text both inherit the themed button foreground (good contrast in
             light and dark). Disabled buttons dim via the default Fluent style. -->
        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Button-like tab headers so they keep contrast on both palettes; the
             brushes come from ThemeManager (pushed into Application resources). -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Margin="0,0,4,0" CornerRadius="4" BorderThickness="1"
                                Background="{DynamicResource TabBgBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}">
                            <ContentPresenter ContentSource="Header" Margin="12,5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabHoverBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabSelectedBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SevNormalBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="LineTemplate">
            <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}"
                       FontFamily="Consolas" FontSize="12.5" TextWrapping="Wrap"
                       Cursor="{Binding Cursor}"
                       FontWeight="{Binding Weight}" Margin="{Binding Margin}"/>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top">
                <Image Source="/Ostrasort-logo.png" Height="78" HorizontalAlignment="Right"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       ToolTip="Ostrasort"/>
                <Button x:Name="BtnUpdate" Margin="0,6,0,0" HorizontalAlignment="Right"
                        Visibility="Collapsed" Padding="10,3" Cursor="Hand" FontWeight="SemiBold"
                        Background="{DynamicResource UpdateBtnBgBrush}"
                        BorderBrush="{DynamicResource UpdateBtnBorderBrush}"
                        Foreground="{DynamicResource UpdateBtnFgBrush}"
                        Click="Update_Click"
                        ToolTip="A newer Ostrasort release has been downloaded. Click to restart and finish updating."/>
                <TextBlock HorizontalAlignment="Right" Margin="0,5,0,0" FontSize="11">
                    <Hyperlink Click="CheckUpdate_Click" ToolTip="Check GitHub for a newer release now and report the result.">Check for updates</Hyperlink>
                </TextBlock>
                <TextBlock HorizontalAlignment="Right" Margin="0,3,0,0" FontSize="11">
                    <Hyperlink Click="ReportBug_Click" ToolTip="Open a pre-filled bug report on GitHub in your browser.">Report a bug</Hyperlink>
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                    <TextBlock Text="Installation" Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <ComboBox x:Name="CmbInstall" MinWidth="200" VerticalAlignment="Center"
                              SelectionChanged="Install_Changed"
                              ToolTip="Switch which game install Ostrasort manages. Add installs (game and mods folders, even on different disks) with Manage."/>
                    <TextBlock VerticalAlignment="Center" Margin="12,0,0,0">
                        <Hyperlink Click="ManageInstalls_Click" ToolTip="Add, edit or remove saved installs and their game / mods folders.">Manage…</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.Resources>
                    <Style x:Key="HdrLabel" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                        <Setter Property="Margin" Value="0,1,14,1"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="HdrValue" TargetType="TextBlock">
                        <Setter Property="Margin" Value="0,1,0,1"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                    </Style>
                </Grid.Resources>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource HdrLabel}" Text="Game folder"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource HdrValue}">
                    <Run x:Name="RunGamePath"/>
                    <Hyperlink Click="OpenGame_Click">open</Hyperlink>
                    <Run x:Name="RunFoundVia" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </TextBlock>

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource HdrLabel}" Text="Mods folder"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource HdrValue}">
                    <Run x:Name="RunModsPath"/>
                    <Hyperlink Click="OpenMods_Click">open</Hyperlink>
                </TextBlock>

                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource HdrLabel}" Text="Game version"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource HdrValue}" x:Name="TxtVersions"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource HdrLabel}" Text="Core data"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource HdrValue}" x:Name="TxtCoreInfo"/>
                </Grid>
            </StackPanel>
        </DockPanel>

        <!-- toolbar -->
        <DockPanel Grid.Row="1" Margin="0,0,0,6">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnUndo" Content="Undo" Padding="12,2" Margin="0,0,6,0" Click="Undo_Click"/>
                <Button x:Name="BtnRedo" Content="Redo" Padding="12,2" Margin="0,0,18,0" Click="Redo_Click"/>
                <TextBlock Text="Theme:" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="CmbTheme" Width="100" VerticalAlignment="Center" Margin="0,0,18,0"
                          SelectionChanged="Theme_Changed"
                          ToolTip="Light, dark, or follow the Windows system theme.">
                    <ComboBoxItem Content="System"/>
                    <ComboBoxItem Content="Light"/>
                    <ComboBoxItem Content="Dark"/>
                </ComboBox>
                <CheckBox x:Name="ChkTidy" Content="Group suggested order by category" VerticalAlignment="Center"
                          Margin="0,0,18,0" Checked="Tidy_Changed" Unchecked="Tidy_Changed"
                          ToolTip="Only affects the SUGGESTED order (cosmetic, opt-in): groups it as core, infrastructure, code, shells, additive data, overrides, patch. It does not regroup the table below."/>
                <CheckBox x:Name="ChkTechCols" Content="Technical columns" VerticalAlignment="Center"
                          Margin="0,0,18,0" Checked="TechCols_Changed" Unchecked="TechCols_Changed"
                          ToolTip="Show the diagnostic columns (Source, Class, Data, Workshop ID). Hidden by default; everything they show is also in reports."/>
                <TextBlock VerticalAlignment="Center" Margin="0,0,4,0">
                    <Hyperlink Click="CopyReport_Click">Copy report</Hyperlink>
                </TextBlock>
                <TextBlock VerticalAlignment="Center" Margin="10,0,0,0">
                    <Hyperlink Click="SaveReport_Click">Save report…</Hyperlink>
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnInstallZip" Content="Install from file…" Padding="12,2" Margin="0,0,18,0"
                        VerticalAlignment="Center" Click="InstallZip_Click"
                        ToolTip="Install a mod from a .zip package (also: drag a .zip onto this window). Extracts it into the game and adds it to the load order."/>
                <TextBlock Text="Filter:" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="TxtFilter" Width="240" VerticalAlignment="Center"
                         TextChanged="Filter_Changed"
                         ToolTip="Filter by name, ID, class, source or notes. Drag-reordering is disabled while filtering."/>
                <TextBlock x:Name="TxtDragHint" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="14,0,0,0"
                           Text="drag rows to reorder manually"/>
            </StackPanel>
        </DockPanel>

        <!-- banners: setup health + FFU/OstraAutoloader (collapsed when not relevant) -->
        <StackPanel Grid.Row="2">
            <Border x:Name="HealthBanner" Visibility="Collapsed" CornerRadius="4"
                    BorderThickness="1" Padding="12,9" Margin="0,0,0,8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button x:Name="BtnHealthFix" Content="Fix automatically" Padding="14,6" FontWeight="SemiBold"
                                Visibility="Collapsed" Click="HealthFix_Click"
                                ToolTip="Apply the suggested load order and create or refresh the compatibility patch in one go. You are only asked when a genuine decision is needed, and every write keeps a backup."/>
                        <Button x:Name="BtnHealthLog" Content="What went wrong?" Padding="14,6" Margin="8,0,0,0"
                                Visibility="Collapsed" Click="HealthLog_Click"
                                ToolTip="See the problems Ostranauts itself reported on its last launch, matched to the responsible mods, with one-click fixes."/>
                        <Button x:Name="BtnHealthShow" Content="Show me" Padding="14,6" Margin="8,0,0,0"
                                Visibility="Collapsed" Click="HealthShow_Click"
                                ToolTip="Open the tab that explains these issues."/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TxtHealthTitle" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock x:Name="TxtHealthDetail" TextWrapping="Wrap" FontSize="12.5" Margin="0,3,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            <Border x:Name="FfuBanner" Visibility="Collapsed" CornerRadius="4"
                    BorderThickness="1" Padding="10,7" Margin="0,0,0,8"
                    Background="{DynamicResource BannerInfoBgBrush}"
                    BorderBrush="{DynamicResource BannerInfoBorderBrush}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Top" Margin="12,0,0,0">
                        <Hyperlink Click="FfuBannerDismiss_Click">dismiss</Hyperlink>
                    </TextBlock>
                    <StackPanel>
                        <TextBlock x:Name="TxtFfuBannerTitle" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <ItemsControl x:Name="ListFfuBanner">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,1,0,1" FontSize="12.5"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,7,0,1">
                            <Button x:Name="BtnDisableAutoloader" Content="Disable OstraAutoloader…"
                                    Visibility="Collapsed" Padding="12,4" Margin="0,0,8,0"
                                    Click="DisableAutoloader_Click"
                                    ToolTip="Park the autoloader DLL(s) as .disabled (reversible) or delete them, so Ostrasort can manage the load order. r2modman users should disable the mod in their profile instead."/>
                            <Button x:Name="BtnRemoveFfu" Content="Remove FFU…"
                                    Visibility="Collapsed" Padding="12,4"
                                    Click="RemoveFfu_Click"
                                    ToolTip="Park the FFU MonoMod DLLs and Minor Fixes Plus as .disabled (reversible) or delete them, and unregister them from the load order."/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>
        </StackPanel>

        <!-- main content: mod table on the left, the detail console on the right,
             side by side so both get the full height and the width is not wasted -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="500"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="2*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

        <!-- mod table + its selected-mod action bar -->
        <DockPanel Grid.Column="0">
        <!-- actions for the selected mod (hover a row for its description) -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,6" Padding="0,0,0,6"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource GridLineBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Selected:" Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="TxtRowActionTarget" Text="Select a mod for actions"
                           VerticalAlignment="Center" Margin="0,0,16,0" MaxWidth="280"
                           TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                <Button x:Name="BtnRowDescription" Style="{StaticResource RowActionButton}" Click="RowDescription_Click"
                        ToolTip="Show this mod's Steam Workshop / mod_info description (formatted).">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Description" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnRowDetails" Style="{StaticResource RowActionButton}" Click="MenuDetails_Click"
                        ToolTip="Everything about this mod in one place: status, problems, game-log issues, and its conflicts (also on double-click).">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Details" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnRowFolder" Style="{StaticResource RowActionButton}" Click="MenuOpenFolder_Click"
                        ToolTip="Open this mod's folder in Explorer.">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Open folder" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnRowWorkshop" Style="{StaticResource RowActionButton}" Click="MenuOpenWorkshop_Click"
                        ToolTip="Open this mod's Steam Workshop page in your browser.">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Workshop page" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnRowRemove" Style="{StaticResource RowActionButton}" Click="MenuDeleteMod_Click"
                        ToolTip="Remove this mod: park the folder as *.disabled (reversible) or delete it, and drop its load-order entry.">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Remove" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
        <DataGrid x:Name="ModsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="False"
                  SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource GridLineBrush}" RowHeaderWidth="0" FontSize="12.5"
                  MouseDoubleClick="ModsGrid_MouseDoubleClick"
                  SelectionChanged="ModsGrid_SelectionChanged"
                  PreviewMouseLeftButtonDown="ModsGrid_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="ModsGrid_PreviewMouseMove"
                  PreviewMouseRightButtonDown="ModsGrid_PreviewMouseRightButtonDown"
                  AllowDrop="True" DragOver="ModsGrid_DragOver" Drop="ModsGrid_Drop">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="{Binding Brush}"/>
                    <Setter Property="ToolTip" Value="{Binding Tooltip}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu Opened="RowMenu_Opened">
                    <MenuItem x:Name="MenuDetails" Header="Mod details…" FontWeight="SemiBold" Click="MenuDetails_Click"
                              ToolTip="Everything about this mod in one place: status, problems, game-log issues, and its conflicts (also on double-click)."/>
                    <MenuItem x:Name="MenuOpenFolder" Header="Open folder" Click="MenuOpenFolder_Click"/>
                    <MenuItem x:Name="MenuOpenWorkshop" Header="Open Steam Workshop page" Click="MenuOpenWorkshop_Click"/>
                    <Separator/>
                    <MenuItem x:Name="MenuDisable" Header="Disable (keep entry, skip at load)" Click="MenuDisable_Click"
                              ToolTip="Adds the game's own |disabled marker to this entry - the same thing the in-game MODS screen toggle does. The mod stays installed and listed but does not load."/>
                    <MenuItem x:Name="MenuEnable" Header="Enable" Click="MenuEnable_Click"
                              ToolTip="Removes the |disabled marker so the mod loads again (local mods get their |edit marker back)."/>
                    <MenuItem x:Name="MenuRegister" Header="Register mod (add to load order)" Click="MenuRegister_Click"
                              ToolTip="Add this unregistered mod to loading_order.json so the game loads it and the MODS screen lists it. It lands where “Apply Suggested Fixes” would place it (local mods get their |edit marker). Undoable; the game must be closed."/>
                    <MenuItem x:Name="MenuIgnore" Header="Ignore (leave unregistered)" Click="MenuIgnore_Click"
                              ToolTip="Stop warning about this unregistered folder and stop suggesting to register it. It stays on disk, invisible to the game, until you register it or stop ignoring it."/>
                    <MenuItem x:Name="MenuUnignore" Header="Stop ignoring" Click="MenuUnignore_Click"
                              ToolTip="Warn about this unregistered folder again and offer to register it."/>
                    <MenuItem x:Name="MenuMarkFfu" Header="Mark as FFU-dependent (load after Minor Fixes Plus)" Click="MenuMarkFfu_Click"
                              ToolTip="For an FFU mod Ostrasort can't auto-detect (e.g. a Workshop mod with no Autoload.Meta.toml): sort it into the FFU block, after Minor Fixes Plus, instead of before it. A sorting preference only - no game files are touched, and it's remembered per install."/>
                    <MenuItem x:Name="MenuUnmarkFfu" Header="Stop treating as FFU-dependent" Click="MenuUnmarkFfu_Click"
                              ToolTip="Remove the manual FFU tag so this mod sorts normally again."/>
                    <MenuItem x:Name="MenuLoadPriority" Header="Load priority"
                              ToolTip="Pin where this mod loads. Late = final say (loads last, like a character-generation mod, so its changes win). Early = yields to other mods. A sorting preference only - no game files are touched, and it's remembered per install.">
                        <MenuItem x:Name="MenuPriorityLate" Header="Late (final say)" IsCheckable="True" Click="MenuPriorityLate_Click"
                                  ToolTip="Load this mod last so its overrides win - for a mod that must have the final say (e.g. it curates character generation)."/>
                        <MenuItem x:Name="MenuPriorityNormal" Header="Normal" IsCheckable="True" Click="MenuPriorityNormal_Click"
                                  ToolTip="Neutral placement - pin here to cancel an auto-detected late placement."/>
                        <MenuItem x:Name="MenuPriorityEarly" Header="Early (yields to others)" IsCheckable="True" Click="MenuPriorityEarly_Click"
                                  ToolTip="Load this mod early so other mods override it."/>
                        <Separator/>
                        <MenuItem x:Name="MenuPriorityAuto" Header="Auto (detected)" IsCheckable="True" Click="MenuPriorityAuto_Click"
                                  ToolTip="Clear the pin and let Ostrasort detect the priority from the mod's contents."/>
                    </MenuItem>
                    <MenuItem x:Name="MenuDeleteMod" Header="Remove mod (park or delete)…" Click="MenuDeleteMod_Click"
                              ToolTip="Park the mod folder as *.disabled (reversible) or delete it permanently, and drop its load-order entry either way. Deleted files are NOT restored by Ostrasort's undo."/>
                    <MenuItem x:Name="MenuUnsubscribe" Header="Unsubscribe on Steam…" Click="MenuUnsubscribe_Click"
                              ToolTip="Workshop subscriptions belong to Steam, so this opens the item's page in the Steam client - use its Unsubscribe button there, then rescan. Steam removes the files itself."/>
                    <Separator x:Name="MenuStateSeparator"/>
                    <MenuItem x:Name="MenuCopyName" Header="Copy mod name" Click="MenuCopyName_Click"/>
                    <MenuItem x:Name="MenuCopyId" Header="Copy Workshop ID" Click="MenuCopyId_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="30">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusGlyph}" Foreground="{Binding StatusBrush}"
                                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       ToolTip="{Binding StatusTip}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Active" Width="52">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Enabled, Mode=OneWay}" IsEnabled="{Binding CanToggle}"
                                      Visibility="{Binding ToggleVisibility}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Click="RowEnable_Click"
                                      ToolTip="Active: the game loads this mod. Unticking adds the game's own disabled marker, the same thing the in-game MODS screen toggle does."/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="#" Binding="{Binding Pos}" Width="36"/>
                <DataGridTextColumn Header="Mod Name" Binding="{Binding Name}" Width="3*"/>
                <DataGridTextColumn x:Name="ColSource" Header="Source" Binding="{Binding Source}" Width="86"/>
                <DataGridTextColumn x:Name="ColClass" Header="Class" Binding="{Binding Class}" Width="110"/>
                <DataGridTextColumn x:Name="ColData" Header="Data" Binding="{Binding Data}" Width="130"/>
                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="80"/>
                <DataGridTextColumn x:Name="ColWorkshopId" Header="Workshop ID" Binding="{Binding WorkshopId}" Width="110"/>
                <DataGridTemplateColumn Header="Last Updated" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LastUpdated}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding UpdateText}" Foreground="{Binding UpdateBrush}"
                                           FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"
                                           ToolTip="A newer version is published on the Steam Workshop. Ostranauts updates subscribed mods automatically the next time you launch it."/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent"/>

        <!-- detail console -->
        <TabControl Grid.Column="2" x:Name="Tabs" FontSize="12.5">
            <TabItem x:Name="TabProfiles" Header="Profiles">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="8,2,8,8">
                        <Button x:Name="BtnProfileSave" Content="Save current…" Padding="10,4" Click="ProfileSave_Click"
                                ToolTip="Save the current load order as a named profile you can switch back to later."/>
                        <Button x:Name="BtnProfileSwitch" Content="Switch…" Padding="10,4" Margin="8,0,0,0" Click="ProfileSwitch_Click"
                                ToolTip="Load the selected profile — shows a diff and a Replace / Merge-append choice before writing anything."/>
                        <Button x:Name="BtnProfileRename" Content="Rename…" Padding="10,4" Margin="8,0,0,0" Click="ProfileRename_Click"/>
                        <Button x:Name="BtnProfileDelete" Content="Delete" Padding="10,4" Margin="8,0,0,0" Click="ProfileDelete_Click"
                                ToolTip="Delete the saved profile. This removes only the profile, never any mods."/>
                        <TextBlock x:Name="TxtProfileHint" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    </StackPanel>
                    <ListBox x:Name="ListProfiles" Margin="8" SelectionChanged="Profiles_SelectionChanged"
                             MouseDoubleClick="Profiles_DoubleClick"
                             ToolTip="Saved load-order sets for this install. Select one, then Switch… to load it.">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,3">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11.5"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>
            <TabItem x:Name="TabCollisions" Header="Conflicts">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="8,6,8,0" TextWrapping="Wrap" FontSize="11.5"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="Tip: double-click a collision (the • line) to see each mod's values side by side."/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListCollisions" ItemTemplate="{StaticResource LineTemplate}" Margin="8"
                                      MouseDoubleClick="Collision_DoubleClick"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
            <TabItem x:Name="TabResolved" Header="Handled automatically">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="8,6,8,0" TextWrapping="Wrap" FontSize="11.5"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="Tip: double-click a collision (the • line) to see each mod's values side by side."/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListResolved" ItemTemplate="{StaticResource LineTemplate}" Margin="8"
                                      MouseDoubleClick="Collision_DoubleClick"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
            <TabItem x:Name="TabOrder" Header="Load order">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListOrder" ItemTemplate="{StaticResource LineTemplate}" Margin="8"/>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="TabPatch" Header="Compatibility patch">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="8,2,8,8">
                        <Button x:Name="BtnPatchGenerate" Content="Resolve conflicts &amp; generate patch" Padding="10,4"
                                Click="Patch_Click"
                                ToolTip="Merge the conflicts no load order can fix into a small generated mod that loads after everything it merges. You decide any contested values; every decision is remembered."/>
                        <Button x:Name="BtnPatchFresh" Content="Rebuild patch from scratch…" Padding="10,4" Margin="8,0,0,0"
                                Click="PatchFresh_Click"
                                ToolTip="Discard every stored decision (source picks AND exclusions) and resolve all conflicts again from a blank slate."/>
                        <Button x:Name="BtnPatchDelete" Content="Remove patch" Padding="10,4" Margin="8,0,0,0"
                                Click="Unpatch_Click"
                                ToolTip="Remove the generated patch mod and its load-order entry. Safe: it can be regenerated any time."/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListPatch" ItemTemplate="{StaticResource LineTemplate}" Margin="8"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
            <TabItem x:Name="TabWarnings" Header="Warnings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListWarnings" ItemTemplate="{StaticResource LineTemplate}" Margin="8"/>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="TabLogs" Header="Logs">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="8,6,8,2">
                        <TextBlock DockPanel.Dock="Left" Text="Show:" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbLogSource" Width="260" VerticalAlignment="Center"
                                  SelectionChanged="LogSource_Changed">
                            <ComboBoxItem Content="Ostrasort operations" IsSelected="True"/>
                            <ComboBoxItem Content="Game log (Player.log)"/>
                            <ComboBoxItem Content="BepInEx log (code mods)"/>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">
                                <Hyperlink Click="RefreshLog_Click">Refresh</Hyperlink>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">
                                <Hyperlink Click="CopyLog_Click">Copy</Hyperlink>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">
                                <Hyperlink Click="ClearLog_Click">Clear Logs</Hyperlink>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center">
                                <Hyperlink Click="OpenLog_Click">Open file</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                    <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListLogs" ItemTemplate="{StaticResource LineTemplate}" Margin="8"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>
        </Grid>

        <!-- action bar: status on the left; the occasional actions and the one
             primary action (Launch) laid out in full on the right -->
        <DockPanel Grid.Row="4" Margin="0,10,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="BtnRescan" Content="Rescan" Padding="14,6" Margin="8,0,0,0" Click="Rescan_Click"
                        ToolTip="Re-read the install now (this also happens automatically when the window regains focus)."/>
                <Button x:Name="BtnBackupNow" Content="Make backup now" Padding="14,6" Margin="8,0,0,0" Click="MakeBackup_Click"
                        ToolTip="Snapshot the current loading_order.json into the rolling backup history."/>
                <Button x:Name="BtnRestoreBak" Content="Restore backup…" Padding="14,6" Margin="8,0,0,0" Click="RestoreBak_Click"
                        ToolTip="Restore loading_order.json from the .bak or a rolling backup."/>
                <Button x:Name="BtnRemovePatch" Content="Remove compatibility patch…" Padding="14,6" Margin="8,0,0,0" Click="Unpatch_Click"
                        ToolTip="Delete the generated patch mod and its load-order entry. Safe: it can be regenerated any time."/>
                <Button x:Name="BtnApplyManual" Content="Apply manual order" Padding="14,6" Margin="8,0,0,0"
                        Visibility="Collapsed" FontWeight="SemiBold" Click="Apply_Click"
                        ToolTip="Write the row arrangement you dragged into loading_order.json (a backup is kept)."/>
                <Button x:Name="BtnLaunch" Content="Launch game" Padding="14,6" Margin="8,0,0,0" Click="Launch_Click"/>
            </StackPanel>
            <TextBlock VerticalAlignment="Center">
                <Run x:Name="RunStatus" FontWeight="SemiBold"/>
                <Hyperlink x:Name="LinkReset" Click="ResetManual_Click"><Run Text="reset arrangement"/></Hyperlink>
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>
