<Window x:Class="Ostrasort.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ostrasort" Height="760" Width="1120" MinHeight="560" MinWidth="860"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate x:Key="LineTemplate">
            <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}"
                       FontFamily="Consolas" FontSize="12.5" TextWrapping="Wrap"
                       Margin="{Binding Margin}"/>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="1.4*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button x:Name="BtnRescan" DockPanel.Dock="Right" Content="Rescan" Padding="16,4"
                    VerticalAlignment="Top" Click="Rescan_Click"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.Resources>
                    <Style x:Key="HdrLabel" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Gray"/>
                        <Setter Property="Margin" Value="0,1,14,1"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="HdrValue" TargetType="TextBlock">
                        <Setter Property="Margin" Value="0,1,0,1"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                    </Style>
                </Grid.Resources>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Name="TxtTitle" FontSize="18"
                           FontWeight="SemiBold" Text="Ostrasort" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource HdrLabel}" Text="Game folder"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource HdrValue}">
                    <Run x:Name="RunGamePath"/>
                    <Hyperlink Click="OpenGame_Click">open</Hyperlink>
                    <Run x:Name="RunFoundVia" Foreground="Gray"/>
                </TextBlock>

                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource HdrLabel}" Text="Mods folder"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource HdrValue}">
                    <Run x:Name="RunModsPath"/>
                    <Hyperlink Click="OpenMods_Click">open</Hyperlink>
                </TextBlock>

                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource HdrLabel}" Text="Versions"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource HdrValue}" x:Name="TxtVersions"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource HdrLabel}" Text="Core data"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource HdrValue}" x:Name="TxtCoreInfo"/>
            </Grid>
        </DockPanel>

        <!-- mod table -->
        <DataGrid Grid.Row="1" x:Name="ModsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EEE" RowHeaderWidth="0" FontSize="12.5"
                  MouseDoubleClick="ModsGrid_MouseDoubleClick">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="{Binding Brush}"/>
                    <Setter Property="ToolTip" Value="{Binding Tooltip}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding Pos}" Width="36"/>
                <DataGridTextColumn Header="Mod Name" Binding="{Binding Name}" Width="3*"/>
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="86"/>
                <DataGridTextColumn Header="Class" Binding="{Binding Class}" Width="110"/>
                <DataGridTextColumn Header="Data" Binding="{Binding Data}" Width="130"/>
                <DataGridTextColumn Header="Workshop ID" Binding="{Binding WorkshopId}" Width="110"/>
                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="4*"/>
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Height="6" Background="Transparent"/>

        <!-- detail tabs -->
        <TabControl Grid.Row="3" x:Name="Tabs" FontSize="12.5">
            <TabItem x:Name="TabCollisions" Header="Collisions">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListCollisions" ItemTemplate="{StaticResource LineTemplate}" Margin="8"/>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="TabOrder" Header="Order changes">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListOrder" ItemTemplate="{StaticResource LineTemplate}" Margin="8"/>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="TabPatch" Header="Patch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListPatch" ItemTemplate="{StaticResource LineTemplate}" Margin="8"/>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="TabWarnings" Header="Warnings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListWarnings" ItemTemplate="{StaticResource LineTemplate}" Margin="8"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- action bar -->
        <DockPanel Grid.Row="4" Margin="0,10,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="BtnApply" Content="Apply suggested order" Padding="14,6" Margin="8,0,0,0" Click="Apply_Click"/>
                <Button x:Name="BtnPatch" Content="Resolve conflicts &amp; generate patch" Padding="14,6" Margin="8,0,0,0" Click="Patch_Click"/>
                <Button x:Name="BtnUnpatch" Content="Remove patch" Padding="14,6" Margin="8,0,0,0" Click="Unpatch_Click"/>
            </StackPanel>
            <TextBlock x:Name="TxtStatus" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </DockPanel>
    </Grid>
</Window>
