<Window x:Class="Ostrasort.Gui.ResolverDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resolve contested items" Height="640" Width="860" MinHeight="420" MinWidth="640"
        Icon="/app.ico" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <DockPanel Margin="12">
        <TextBlock x:Name="TxtIntro" DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="Gray"
                   Text="Where two mods change the same shop item or object field to different values, pick which one the merged patch keeps (or the union / vanilla). Everything the mods agree on, or only one of them touched, merges automatically — expand those to review. All decisions are remembered for future refreshes. Merged game objects are best-effort: verify them in game."/>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="TxtRemaining" VerticalAlignment="Center" Margin="0,0,14,0" Foreground="Gray"/>
            <Button x:Name="BtnOk" Content="Generate patch" Padding="16,6" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" Padding="16,6" Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PoolsHost"/>
        </ScrollViewer>
    </DockPanel>
</Window>
