<Window x:Class="Ostrasort.Gui.ResolverDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resolve contested items" Height="640" Width="860" MinHeight="420" MinWidth="640"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="Gray"
                   Text="These mods stock the same items with different values. Pick which mod's entry the merged pool keeps — items only one mod stocks are carried over automatically. Your choices are remembered for future refreshes."/>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="TxtRemaining" VerticalAlignment="Center" Margin="0,0,14,0" Foreground="Gray"/>
            <Button x:Name="BtnOk" Content="Generate patch" Padding="16,6" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" Padding="16,6" Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PoolsHost"/>
        </ScrollViewer>
    </DockPanel>
</Window>
