<Window x:Class="Ostrasort.Gui.ParkOrDeleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ostrasort" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" WindowStyle="ToolWindow">
    <StackPanel Margin="18,14" MaxWidth="440">
        <TextBlock x:Name="TxtHeader" FontWeight="SemiBold" FontSize="13.5" TextWrapping="Wrap" Margin="0,0,0,6"/>
        <TextBlock x:Name="TxtBody" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,14"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Park (reversible)" Padding="12,4" Margin="0,0,8,0" IsDefault="True" Click="Park_Click"
                    ToolTip="Rename to *.disabled — rename back to restore."/>
            <Button Content="Delete files" Padding="12,4" Margin="0,0,8,0" Click="Delete_Click"
                    ToolTip="Remove the files permanently — no leftovers, not undoable by Ostrasort."/>
            <Button Content="Cancel" Padding="12,4" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
