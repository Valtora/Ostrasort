<Window x:Class="Ostrasort.Gui.RivalStackDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ostrasort — FFU / Thunderstore stack detected"
        SizeToContent="Height" Width="640" MinWidth="540"
        ResizeMode="NoResize" ShowInTaskbar="True" Icon="/app.ico"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="22">
        <TextBlock Text="A different mod framework is installed"
                   FontSize="17" FontWeight="Bold" Foreground="Firebrick" Margin="0,0,0,10"/>
        <TextBlock x:Name="TxtBody" TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="20"/>
        <Border Background="#FFFBF3F3" BorderBrush="#FFE6C9C9" BorderThickness="1"
                Padding="10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Detected on this install:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock x:Name="TxtEvidence" TextWrapping="Wrap"
                           FontFamily="Consolas" FontSize="12"/>
            </StackPanel>
        </Border>
        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,18" LineHeight="19"
                   Text="Use one or the other, not both — manage your Steam Workshop mods with Ostrasort, or let the OstraAutoloader manage your FFU / Thunderstore mods. Ostrasort is Steam-Workshop-first and does not support the Thunderstore/FFU stack; continuing anyway may break your FFU setup."/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnQuit" Content="Quit Ostrasort" Padding="18,7"
                    IsDefault="True" IsCancel="True" Click="Quit_Click"/>
            <Button x:Name="BtnContinue" Content="Continue anyway" Padding="18,7"
                    Margin="10,0,0,0" Click="Continue_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
