<Window x:Class="Ostrasort.Gui.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ostrasort" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" WindowStyle="ToolWindow">
    <StackPanel Margin="18,14" MaxWidth="440">
        <TextBlock x:Name="TxtHeader" FontWeight="SemiBold" FontSize="13.5" TextWrapping="Wrap" Margin="0,0,0,6"/>
        <TextBlock x:Name="TxtBody" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,14"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnDownload" Content="Download Latest Version" Padding="12,4" Margin="0,0,8,0" Click="Download_Click"/>
            <Button x:Name="BtnNotNow" Content="Not Now" Padding="12,4" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
