<Window x:Class="Ostrasort.Gui.LogIssuesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What went wrong last launch" Height="560" Width="720" MinHeight="380" MinWidth="520"
        Icon="/app.ico" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <DockPanel Margin="14">
        <TextBlock x:Name="TxtIntro" DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock VerticalAlignment="Center" Margin="0,0,14,0">
                <Hyperlink Click="OpenLog_Click" ToolTip="Open the game's own log file (Player.log).">Open the game log</Hyperlink>
            </TextBlock>
            <Button Content="Close" Padding="16,6" IsDefault="True" IsCancel="True"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="Body" Margin="0,0,6,0"/>
        </ScrollViewer>
    </DockPanel>
</Window>
